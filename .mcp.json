{
  "name": "ecommerce-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 \u0001",
  "version": "1.0.0",
  "tools": [
    {
      "name": "write_product_description",
      "description": "Generate a compelling product description for an e-commerce listing.",
      "parameters": {
        "type": "object",
        "properties": {
          "product_name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "features": {
            "type": "array"
          },
          "target_audience": {
            "type": "string"
          },
          "tone": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "include_bullet_points": {
            "type": "boolean"
          }
        },
        "required": [
          "product_name",
          "category",
          "features"
        ]
      }
    },
    {
      "name": "optimize_pricing",
      "description": "Optimize product pricing using market data and strategy.",
      "parameters": {
        "type": "object",
        "properties": {
          "cost": {
            "type": "number"
          },
          "competitor_prices": {
            "type": "number"
          },
          "strategy": {
            "type": "string"
          },
          "target_margin_pct": {
            "type": "number"
          },
          "demand_level": {
            "type": "string"
          }
        },
        "required": [
          "cost"
        ]
      }
    },
    {
      "name": "summarize_reviews",
      "description": "Summarize product reviews into actionable insights.",
      "parameters": {
        "type": "object",
        "properties": {
          "reviews": {
            "type": "array"
          }
        },
        "required": [
          "reviews"
        ]
      }
    },
    {
      "name": "forecast_inventory",
      "description": "Forecast inventory needs and generate reorder recommendations.",
      "parameters": {
        "type": "object",
        "properties": {
          "product_name": {
            "type": "string"
          },
          "current_stock": {
            "type": "integer"
          },
          "daily_sales_avg": {
            "type": "number"
          },
          "lead_time_days": {
            "type": "integer"
          },
          "safety_stock_days": {
            "type": "integer"
          },
          "sales_history": {
            "type": "number"
          },
          "seasonal_factor": {
            "type": "number"
          }
        },
        "required": [
          "product_name",
          "current_stock",
          "daily_sales_avg"
        ]
      }
    },
    {
      "name": "generate_seo_meta",
      "description": "Generate SEO-optimized meta tags for product pages.",
      "parameters": {
        "type": "object",
        "properties": {
          "product_name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "features": {
            "type": "array"
          },
          "brand": {
            "type": "string"
          },
          "target_keywords": {
            "type": "array"
          }
        },
        "required": [
          "product_name",
          "category",
          "features"
        ]
      }
    }
  ]
}